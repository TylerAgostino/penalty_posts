# Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# Discord Bot Token
# Get this from: https://discord.com/developers/applications
BOT_TOKEN=your-discord-bot-token-here

# OIDC Configuration (Required for Google OAuth authentication)
# Get these credentials from: https://console.cloud.google.com/apis/credentials

# Your Google OAuth 2.0 Client ID
OIDC_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Your Google OAuth 2.0 Client Secret
OIDC_CLIENT_SECRET=your-client-secret

# OIDC Issuer URL (defaults to Google if not specified)
OIDC_ISSUER_URL=https://accounts.google.com

# Optional: Restrict access to specific email domains (comma-separated)
# Example: OIDC_ALLOWED_DOMAINS=example.com,anotherdomain.com
OIDC_ALLOWED_DOMAINS=

# Optional: Restrict access to specific email addresses (comma-separated)
# Example: OIDC_ALLOWED_EMAILS=user1@example.com,user2@example.com
OIDC_ALLOWED_EMAILS=
